RACK_ENV=production
PORT=3001
POSTGRES_DB=ativa_idoso_api_production
POSTGRES_USER=ativa_idoso
POSTGRES_PASSWORD=change-this-to-a-long-random-password
DATABASE_POOL_SIZE=10
CORS_ALLOWED_ORIGINS=https://ativa-idoso.com.br

# Application secrets: replace every example value before deploying.
JWT_ALGORITHM=HS256
JWT_ISSUER=ativa-idoso
ENCRYPTION_KEY=replace-with-a-long-random-secret
HTTP_AUTHORIZATION=replace-if-required
